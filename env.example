# BULLHORN_AUTH_URL=https://auth.bullhornstaffing.com
# BULLHORN_CLIENT_ID=
# BULLHORN_CLIENT_SECRET=
# BULLHORN_USERNAME=
# BULLHORN_PASSWORD=
# SUPABASE_SERVICE_ROLE_KEY=
